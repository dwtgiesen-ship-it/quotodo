# Supabase — create a project at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Anthropic — get an API key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your_key_here

# Resend (optional — required for "Send to Client" email feature)
# Sign up at https://resend.com
RESEND_API_KEY=
RESEND_FROM_EMAIL=onboarding@resend.dev

# App URL — used to build public quote share links
# Local dev:   http://localhost:3000
# Production:  https://your-domain.com (set this on Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000
